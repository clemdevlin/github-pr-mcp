  },
  "dependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "agents": "^0.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
