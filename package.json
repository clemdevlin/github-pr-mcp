{
  "name": "github-pr-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "secret:put-token": "wrangler secret put GITHUB_TOKEN",
    "inspector": "node --loader ts-node/esm src/inspector.ts",
